# ============================================================
# Golden Voices Connect — Server Environment Variables
# ============================================================
# Copy this file to .env.server and fill in all values.
# Wasp reads .env.server at startup for server-side config.
# NEVER commit .env.server — it's in .gitignore
# ============================================================

# ─── Database (Supabase PostgreSQL) ─────────────────────────
# Get from: Supabase Dashboard → Settings → Database → Connection string
# Format: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# The ?sslmode=require and 6543 port indicate Supabase's PgBouncer pooler (recommended)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require"

# ─── Authentication: Clerk ───────────────────────────────────
# Get from: https://dashboard.clerk.com → your app → API Keys
# PUBLISHABLE key is safe to expose in client code
CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk webhook secret — used by Wasp auth webhook at POST /webhooks/clerk
# Get from: Clerk Dashboard → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET="whsec_..."

# ─── Payments: Stripe ───────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
# Use test keys (pk_test_ / sk_test_) during development
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe webhook secret — verify webhook signatures from Stripe
# Get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Command to get: stripe listen --print-secret (in stripe CLI)
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Email: Resend ──────────────────────────────────────────
# Get from: https://resend.com → API Keys → Create API Key
# Domain must be verified at: https://resend.com/domains
RESEND_API_KEY="re_..."

# ─── AI: OpenAI ─────────────────────────────────────────────
# Get from: https://platform.openai.com → API Keys → Create new secret key
# Used for: call summary generation (GPT-4o), AI conversation insights
OPENAI_API_KEY="sk-..."

# ─── Voice Calls: VAPI ───────────────────────────────────────
# Get from: https://app.vapi.ai → Settings → API Keys
VAPI_PRIVATE_KEY="..."

# Create an AI assistant at: https://app.vapi.ai → Assistants → Create Assistant
# The assistant defines the AI persona, greeting, language prompts (en/ur/hi)
VAPI_ASSISTANT_ID="..."

# Get a phone number at: https://app.vapi.ai → Phone Numbers → Buy Number
# This is the number that will CALL the seniors
VAPI_PHONE_NUMBER_ID="..."

# ─── App URLs ───────────────────────────────────────────────
# Public URL of your deployed app (no trailing slash)
# Used for: email links, Stripe webhook registration, Clerk webhook registration
CLIENT_URL="https://your-app-url.com"
APP_URL="http://localhost:3000"

# ─── Server ─────────────────────────────────────────────────
NODE_ENV="development"  # "development" | "production"

# ─── Admin ──────────────────────────────────────────────────
# Comma-separated list of admin email addresses
# Users with these emails get isAdmin=true on first login
ADMIN_EMAILS="ali@example.com"

# ─── Wasp OpenSaaS — Optional Analytics ────────────────────
# Plausible analytics (privacy-friendly, no cookies required)
# Get from: https://plausible.io → Settings → Websites → your site → Share → JS snippet
PLAUSIBLE_DOMAIN="your-site-id"  # e.g. "goldenvoices.app"

# ─── Wasp OpenSaaS — Optional File Upload ───────────────────
# S3-compatible storage for user file uploads
# Supports: AWS S3, Backblaze B2, Cloudflare R2, MinIO
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY for S3
# AWS_S3_BUCKET_NAME and AWS_S3_REGION for bucket config
# AWS_S3_FILE_UPLOAD_BUCKET_URL for direct uploads (signed URLs)
# S3_ENDPOINT for Backblaze/Cloudflare R2/MinIO (leave blank for AWS)
# S3_ENDPOINT_STAGING for staging environment

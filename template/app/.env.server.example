# =============================================================================
# Golden Voices Connect — Environment Variables Reference
# Copy to .env.server and fill in real values. NEVER commit .env.server to git.
# =============================================================================
#
# NOTE: Field names (VARIABLE=) must stay exactly as shown — the app code reads
# these exact names. Only replace the <placeholder> values.
# Use angle-bracket <placeholder> pattern — GitHub secret scanner accepts it.

# ─── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (shared_apps schema)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=golden_voices
DATABASE_URL=<your-neon-postgres-connection-string>

# ─── Clerk Auth ────────────────────────────────────────────────────────────────
# Wasp supports Clerk as an auth provider. Get from https://dashboard.clerk.com
# If not using Clerk, remove Clerk-related fields from env.ts and main.wasp
CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
CLERK_SECRET_KEY=<your-clerk-secret-key>

# ─── VAPI — Voice AI Platform ─────────────────────────────────────────────────
# Get these from https://dashboard.vapi.ai
#
# 1. PRIVATE KEY: dashboard.vapi.ai → API Keys → Create key
VAPI_PRIVATE_KEY=<your-vapi-private-key>

# 2. ASSISTANT ID: Create an outbound assistant in Vapi dashboard
#    The assistant should use GPT-4o-mini, with instructions for
#    elderly check-in calls in English/Urdu/Hindi
VAPI_ASSISTANT_ID=<your-vapi-assistant-id>

# 3. PHONE NUMBER ID: Provision an outbound phone number in Vapi dashboard
#    This is the Vapi-managed number that calls your seniors
VAPI_PHONE_NUMBER_ID=<your-vapi-phone-number-id>

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Used for AI call summaries (GPT-4o-mini) and any GPT features
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-api-key>

# ─── Resend — Transactional Email ─────────────────────────────────────────────
# Used for: call-completed notifications, password reset, onboarding
# Get from: https://resend.com/api-keys
RESEND_API_KEY=<your-resend-api-key>

# ─── Stripe — Payments ─────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>

# Webhook secret — from Stripe dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ─── App Config ───────────────────────────────────────────────────────────────
# Public URL of this app (no trailing slash)
# Used in email CTAs and Stripe redirect URLs
CLIENT_URL=https://goldenvoices.app

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin access
ADMIN_EMAILS=ali@socialdots.ca

# ─── Optional / Future ────────────────────────────────────────────────────────
# Redis URL (if using PgBoss with Redis instead of PostgreSQL as broker)
# REDIS_URL=redis://localhost:6379

# ─── Local Development Only ────────────────────────────────────────────────────
# Wasp CLI sets these automatically; do not set manually
# PORT=3000
# DATABASE_URL (see above)

# =============================================================================
# Golden Voices Connect — Environment Variables Reference
# Copy to .env.server and fill in real values. NEVER commit .env.server to git.
# =============================================================================
#
# NOTE: Field names (VARIABLE=) must stay exactly as shown — the app code reads
# these exact names. Only replace the <placeholder> values.
# Use angle-bracket <placeholder> pattern — GitHub secret scanner accepts it.

# ─── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (shared_apps schema)
# Format: postgresql://USER:***@HOST:PORT/DATABASE?schema=golden_voices
DATABASE_URL=<your-neon-postgres-connection-string>

# ─── Clerk Auth (OPTIONAL — Wasp email/password is active) ──────────────────────
# Clerk is NOT wired in this project. Wasp email/password is in use.
# If you wire Clerk later, get keys from https://dashboard.clerk.com
# CLERK_PUBLISHABLE_KEY=<your-clerk-publishable-key>
# CLERK_SECRET_KEY=<your-clerk-secret-key>

# ─── VAPI — Voice AI Platform ─────────────────────────────────────────────────
# Get these from https://dashboard.vapi.ai
#
# 1. PRIVATE KEY: dashboard.vapi.ai → API Keys → Create key
VAPI_PRIVATE_KEY=<your-vapi-private-key>

# 2. ASSISTANT ID: Create an outbound assistant in Vapi dashboard
#    The assistant should use GPT-4o-mini, with instructions for
#    elderly check-in calls in English/Urdu/Hindi
VAPI_ASSISTANT_ID=<your-vapi-assistant-id>

# 3. PHONE NUMBER ID: Provision an outbound phone number in Vapi dashboard
#    This is the Vapi-managed number that calls your seniors
VAPI_PHONE_NUMBER_ID=<your-vapi-phone-number-id>

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# Used for AI call summaries (GPT-4o-mini) and any GPT features
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=<your-openai-api-key>

# ─── Resend — Transactional Email ─────────────────────────────────────────────
# Used for: call-completed notifications, password reset, onboarding
# Get from: https://resend.com/api-keys
RESEND_API_KEY=<your-resend-api-key>

# ─── Stripe — Payments ─────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=<your-stripe-secret-key>
STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>

# Webhook secret — from Stripe dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ─── Stripe Price IDs ──────────────────────────────────────────────────────────
# Create products in Stripe dashboard → Products
# PAYMENTS_HOBBY_SUBSCRIPTION_PLAN_ID: your hobby/starter plan price ID
# PAYMENTS_PRO_SUBSCRIPTION_PLAN_ID: your pro plan price ID
# PAYMENTS_CREDITS_10_PLAN_ID: your 10-credits top-up price ID
PAYMENTS_HOBBY_SUBSCRIPTION_PLAN_ID=<your-hobby-plan-price-id>
PAYMENTS_PRO_SUBSCRIPTION_PLAN_ID=<your-pro-plan-price-id>
PAYMENTS_CREDITS_10_PLAN_ID=<your-credits-10-plan-price-id>

# ─── AWS S3 — File Uploads ────────────────────────────────────────────────────
# Used for storing uploaded files (recordings, photos, etc.)
# Get from: AWS IAM → Create access key for S3 access
AWS_S3_REGION=<your-aws-region-e-g-us-east-1>
AWS_S3_IAM_ACCESS_KEY=<your-aws-iam-access-key>
AWS_S3_IAM_SECRET_KEY=<your-aws-iam-secret-key>
AWS_S3_FILES_BUCKET=<your-s3-bucket-name>

# ─── Analytics (OPTIONAL — remove from env.ts if not using) ────────────────────
# Plausible Analytics (cookie-free, GDPR-compliant)
# Get from: https://plausible.io/settings#api-keys
# PLAUSIBLE_API_KEY=<your-plausible-api-key>
# PLAUSIBLE_SITE_ID=<your-plausible-site-id>
# PLAUSIBLE_BASE_URL=<your-site-url-e-g-https://goldenvoices.app>

# Google Analytics (requires cookie consent component — see main.wasp)
# Get from: Google Cloud Console → Analytics API
# GOOGLE_ANALYTICS_CLIENT_EMAIL=<your-ga-client-email>
# GOOGLE_ANALYTICS_PRIVATE_KEY=<your-ga-private-key>
# GOOGLE_ANALYTICS_PROPERTY_ID=<your-ga-property-id>

# ─── App Config ───────────────────────────────────────────────────────────────
# Public URL of this app (no trailing slash)
# Used in email CTAs and Stripe redirect URLs
CLIENT_URL=<your-client-url-e-g-https://goldenvoices.app>

# ─── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated emails that get admin access
ADMIN_EMAILS=ali@socialdots.ca

# ─── Local Development Only ────────────────────────────────────────────────────
# Wasp CLI sets these automatically; do not set manually
# PORT=3000
# DATABASE_URL (see above)

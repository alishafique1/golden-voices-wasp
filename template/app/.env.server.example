# ============================================================
# Golden Voices Connect — .env.server.example
# ============================================================
# Copy this file to .env.server and fill in all values.
# All vars are validated at startup via Wasp envValidationSchema.
# ============================================================

# ─── DATABASE ───────────────────────────────────────────────
# PostgreSQL connection string.
# Shared apps DB: postgresql://user:pass@host:port/shared_apps?schema=golden_voices
# Local dev (no DATABASE_URL needed): run `wasp start db` instead
DATABASE_URL=postgresql://golden_app:your_password@host.docker.internal:54320/shared_apps?schema=golden_voices

# ─── AUTH (Wasp built-in email/password) ────────────────────
# Comma-separated list of emails that get isAdmin=true on signup.
# After registering a new admin email, restart the server to pick up the change.
ADMIN_EMAILS=you@example.com

# ─── CLERK ──────────────────────────────────────────────────
# NOTE: Clerk is listed in gvEnvValidationSchema but NOT yet wired in main.wasp auth config.
# The app currently uses Wasp built-in email/password auth.
# To enable Clerk: add clerk: { ... } to the auth block in main.wasp and uncomment below.
# Get keys from: https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ─── VAPI (AI Voice Calls) ─────────────────────────────────
# Get from: https://dashboard.vapi.ai → API Keys
# Private key (server-side only — never expose to client)
VAPI_PRIVATE_KEY=your-vapi-private-key

# Assistant ID — create an outbound assistant in the Vapi dashboard.
# This assistant defines the AI persona, voice, and conversation logic.
VAPI_ASSISTANT_ID=your-vapi-assistant-id

# Phone number ID — must be a Vapi-provisioned number capable of outbound calls.
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id

# ─── OPENAI ─────────────────────────────────────────────────
# Used for: AI call summary generation (GPT-4o-mini) after each completed call.
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── RESEND (Transactional Email) ───────────────────────────
# Used for: call-completed notifications to users.
# Get from: https://resend.com → API Keys
# Domain must be verified (for production) or use a trial domain (for dev).
RESEND_API_KEY=re_...

# ─── STRIPE (Payments) ─────────────────────────────────────
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Get webhook secret by running: stripe listen --forward-to localhost:3001/payments-webhook
# Then copy the "webhook secret" from the CLI output.
STRIPE_PUBLISHABLE_KEY=pk_test_...   # Used client-side (REACT_APP_ prefix added by Wasp)

# ─── CLIENT URL ─────────────────────────────────────────────
# Used in email templates to generate links back to the app.
# Must match the public URL of your deployed app (no trailing slash).
CLIENT_URL=http://localhost:3000

# ─── PAYMENT PLAN IDs (Stripe) ──────────────────────────────
# Create products in Stripe dashboard → Products.
# These are used to generate checkout sessions.
# Example: Free (5 calls/mo), Starter ($19/mo, 30 calls), Premium ($39/mo, unlimited)
PAYMENTS_STARTER_PLAN_PRICE_ID=price_...
PAYMENTS_PREMIUM_PLAN_PRICE_ID=price_...

# ─── LEMONSQUEEZY (Alternative — not currently used) ────────
# Only needed if switching away from Stripe.
LEMONSQUEEZY_API_KEY=...
LEMONSQUEEZY_STORE_ID=...
LEMONSQUEEZY_WEBHOOK_SECRET=...

# ─── POLAR (Alternative — not currently used) ───────────────
# Only needed if using Polar for payments.
POLAR_ORGANIZATION_ACCESS_TOKEN=...
POLAR_WEBHOOK_SECRET=...
POLAR_SANDBOX_MODE=true

# ─── SENDGRID (Legacy email — not currently used) ───────────
# Resend is currently used instead. SendGrid is here for reference.
SENDGRID_API_KEY=...

# ─── ANALYTICS (Optional) ───────────────────────────────────
# Google Analytics 4
REACT_APP_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_ANALYTICS_CLIENT_EMAIL=...@....gserviceaccount.com
GOOGLE_ANALYTICS_PRIVATE_KEY=LS02...
GOOGLE_ANALYTICS_PROPERTY_ID=123456789

# Plausible (privacy-friendly analytics)
PLAUSIBLE_API_KEY=...
PLAUSIBLE_SITE_ID=yoursite.com
PLAUSIBLE_BASE_URL=https://plausible.io/api

# ─── FILE UPLOAD / S3 (Optional) ────────────────────────────
# Only needed if enabling file uploads.
AWS_S3_IAM_ACCESS_KEY=ACK...
AWS_S3_IAM_SECRET_KEY=...
AWS_S3_FILES_BUCKET=your-bucket-name
AWS_S3_REGION=us-east-1

# ─── PGBOSS (Job Queue — automatic via Wasp) ────────────────
# PgBoss settings are auto-configured by Wasp from DATABASE_URL.
# You can override defaults here if needed:
# PGBOSS_REDIS_URL=redis://localhost:6379
# PGBOSS_PREFIX=golden_voices
